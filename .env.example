# .env.example — Variables de entorno del proyecto
# Copia este archivo como .env y completa los valores
# .env está en .gitignore

# Directorios (opcional: sobreescribir lo del config.yaml)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_OUTPUT_DIR=data/output

# APIs de datos ambientales (solo si se usan loaders automáticos)
OPENAQ_API_KEY=
COPERNICUS_API_KEY=
IDEAM_API_KEY=

# Optuna (logging a base de datos externa, opcional)
OPTUNA_STORAGE=
