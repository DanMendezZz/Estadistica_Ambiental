# .env.example — Variables de entorno del proyecto
# Copia este archivo como .env y completa los valores
# .env está en .gitignore

# Directorios (opcional: sobreescribir los valores de config.yaml)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_OUTPUT_DIR=data/output

# Nota: las APIs de datos ambientales usadas en este proyecto son públicas
# y no requieren API key en variables de entorno:
#   - OpenAQ v3: acceso público sin autenticación
#   - RMCAB (SDA Bogotá): usa el parámetro token= directamente en load_rmcab()
#   - SIATA, IDEAM DHIME, SMByC: descarga manual desde sus portales
